{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "struktly/config/v1",
  "type": "object",
  "properties": {
    "schema": { "const": "struktly/config/v1" },
    "context": { "$ref": "#/$defs/context" },
    "checks": { "$ref": "#/$defs/checks" }
  },
  "required": ["schema"],
  "additionalProperties": false,
  "$defs": {
    "strings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "context": {
      "type": "object",
      "properties": {
        "include": { "$ref": "#/$defs/strings" },
        "exclude": { "$ref": "#/$defs/strings" }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "object",
      "properties": {
        "required": { "$ref": "#/$defs/strings" },
        "suggested": { "$ref": "#/$defs/strings" }
      },
      "additionalProperties": false
    }
  }
}
